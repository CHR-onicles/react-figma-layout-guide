{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "commitMessage": "chore(release): react-figma-layout-guide v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "react-figma-layout-guide v${version}",
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "tokenRef": "GITHUB_TOKEN"
  },
  "npm": {
    "publish": true
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits"
      },
      "infile": false,
      "commitsOpts": {
        "path": "packages/react-figma-layout-guide"
      },
      "gitRawCommitsOpts": {
        "path": "packages/react-figma-layout-guide"
      }
    }
  },
  "hooks": {
    "before:init": ["npm run tsc", "npm run test", "npm run build"]
  }
}
